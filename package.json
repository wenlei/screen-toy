{
  "name": "screen-toy",
  "version": "1.0.0",
  "description": "Desktop pixel robot companion",
  "main": "out/electron/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && electron .",
    "start": "electron .",
    "pack": "tsc && electron-builder --dir",
    "dist": "tsc && electron-builder"
  },
  "build": {
    "appId": "com.screentoy.app",
    "productName": "Screen Toy",
    "icon": "src/assets/icon/icon.png",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ]
    },
    "files": [
      "out/**/*",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.0"
  }
}
